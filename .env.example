# App
APP_NAME=Cite Mind
APP_ENV=development
LOG_LEVEL=INFO
MAX_AGENTS=3

# Provider selection: gemini | ollama | openrouter
DEFAULT_LLM_PROVIDER=ollama

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_RETRIES=0

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Paths
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
VECTOR_DB_DIR=./data/vector_db

# Optional later-stage multi-paper RAG
RAG_ENABLED=false
# auto | hash | sentence_transformers
RAG_EMBEDDING_BACKEND=auto
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_HASH_DIMENSIONS=384
RAG_TOP_K=5
RAG_CONTEXT_MAX_CHARS=12000

# Optional local smoke test
LLM_SMOKE_TEST_PROMPT=
